#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_build:
	# Nothing to build — data package

override_dh_auto_install:
	install -d debian/pcdp-templates/usr/share/pcdp/templates
	install -d debian/pcdp-templates/usr/share/pcdp/hints
	install -m 0644 templates/backend-service.template.md  debian/pcdp-templates/usr/share/pcdp/templates/
	install -m 0644 templates/cli-tool.template.md         debian/pcdp-templates/usr/share/pcdp/templates/
	install -m 0644 templates/cloud-native.template.md     debian/pcdp-templates/usr/share/pcdp/templates/
	install -m 0644 templates/gui-tool.template.md         debian/pcdp-templates/usr/share/pcdp/templates/
	install -m 0644 templates/library-c-abi.template.md    debian/pcdp-templates/usr/share/pcdp/templates/
	install -m 0644 templates/mcp-server.template.md       debian/pcdp-templates/usr/share/pcdp/templates/
	install -m 0644 templates/project-manifest.template.md debian/pcdp-templates/usr/share/pcdp/templates/
	install -m 0644 templates/python-tool.template.md      debian/pcdp-templates/usr/share/pcdp/templates/
	install -m 0644 templates/verified-library.template.md debian/pcdp-templates/usr/share/pcdp/templates/
	install -m 0644 hints/cloud-native.go.go-libvirt.hints.md        debian/pcdp-templates/usr/share/pcdp/hints/
	install -m 0644 hints/cloud-native.go.golang-crypto-ssh.hints.md debian/pcdp-templates/usr/share/pcdp/hints/
	install -m 0644 hints/mcp-server.go.mcp-go.hints.md              debian/pcdp-templates/usr/share/pcdp/hints/
